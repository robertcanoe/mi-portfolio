---
import FadeIn from './animations/FadeIn.astro';

interface Experience {
  title: string
  company: string
  location: string
  startDate: string
  endDate: string
  description: string[]
  current?: boolean
}

const EXPERIENCE: Experience[] = [
  {
    title: "Desarrollador Full-Stack (Formación Dual)",
    company: "Deuser / Indra Group — Software Factory OT",
    location: "Córdoba",
    startDate: "Enero 2025",
    endDate: "Actual",
    current: true,
    description: [
      "Desarrollo de aplicaciones industriales con C# y .NET Core (principios SOLID, Clean Architecture).",
      "Integración de sistemas SCADA y comunicación OPC UA con PLCs y Modbus.",
      "Programación de robots KUKA KMR con Sunrise Workbench (Java).",
      "Desarrollo frontend con Angular y React + TypeScript.",
      "Diseño e implementación de APIs REST con Entity Framework Core.",
      "Contenerización con Docker y Docker Compose.",
      "Control de versiones con Git, GitHub y GitHub Copilot.",
    ]
  },
  {
    title: "2º Desarrollo de Aplicaciones Web (DAW)",
    company: "IES Gran Capitán",
    location: "Córdoba",
    startDate: "2024",
    endDate: "Actual",
    current: true,
    description: [
      "Desarrollo Full-Stack con Angular, React, TypeScript y PHP/Laravel.",
      "Backend con .NET Core, Entity Framework y bases de datos SQL/NoSQL.",
      "Arquitectura de software: patrones de diseño, SOLID y microservicios.",
      "DevOps: Docker, CI/CD y despliegue en Vercel.",
      "Proyectos en equipo con Git Flow y metodologías ágiles.",
    ]
  },
  {
    title: "Bachillerato de Ciencias y Tecnología",
    company: "CDP Torrealba",
    location: "Almodóvar del Río, Córdoba",
    startDate: "2022",
    endDate: "2024",
    description: []
  }
]
---

<div class="relative mx-12 pb-12">
  {
    EXPERIENCE.map((experience, index) => (
      <FadeIn x={-30} duration={1.2} delay={index * 0.4}>
        <div class="relative border-s border-gray-200 dark:border-gray-700 ml-3 group">
          <div class="mb-10 ms-6">
            <span class="absolute flex items-center justify-center w-6 h-6 bg-blue-100 rounded-full -start-3 ring-8 ring-white dark:ring-gray-900 dark:bg-blue-900 transition-all duration-300 group-hover:scale-125 group-hover:bg-blue-200 dark:group-hover:bg-blue-800">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" aria-hidden="true" class="w-2.5 h-2.5 text-blue-800 dark:text-blue-300" viewBox="0 0 20 20"><path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20zM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2"/></svg>
            </span>
            <div class="flex items-center gap-3 mb-1 flex-wrap">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white transition-colors duration-300 group-hover:text-blue-600 dark:group-hover:text-blue-400">
                {experience.title} · {experience.company}
              </h3>
              {experience.current && (
                <span class="inline-flex items-center gap-1 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-xs font-medium px-2.5 py-0.5 rounded-full border border-green-300 dark:border-green-700">
                  <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                  Actual
                </span>
              )}
            </div>
            <time class="block mb-2 text-sm font-normal leading-none text-gray-400 dark:text-gray-500 transition-colors duration-300 group-hover:text-blue-500 dark:group-hover:text-blue-400">
              {experience.startDate} - {experience.endDate}
            </time>
            <p class="mb-4 text-base font-normal text-gray-500 dark:text-gray-400 transition-colors duration-300 group-hover:text-gray-700 dark:group-hover:text-gray-300">
              {experience.location}
            </p>
            <ul class="list-disc ml-4">
              {experience.description.map((item) => (
                <li class="mb-2 text-base font-normal text-gray-500 dark:text-gray-400 transition-colors duration-300 group-hover:text-gray-700 dark:group-hover:text-gray-300">
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </FadeIn>
    ))
  }
</div>
