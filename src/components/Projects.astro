---
import FadeIn from './animations/FadeIn.astro';
import HoverScale from './animations/HoverScale.astro';

interface Project {
  title: string
  description: string
  link: string
  github?: string
  image: string
  tags: string[]
}

const PROJECTS: Project[] = [
  {
    title: "BrewScada",
    description: "Aplicación SCADA para la gestión automatizada de la producción de cerveza en una planta cervecera. Monitorización y control de procesos en tiempo real.",
    github: "https://github.com/robertcanoe/BrewScada",
    image: "/assets/images/projects/img_project1.webp",
    tags: ["C#", ".NET", "MongoDB", "WinForms"],
    link: "https://github.com/robertcanoe/BrewScada"
  },
  {
    title: "Escape de la Terminal",
    description: "Juego educativo tipo escape room para aprender comandos de Linux de forma inmersiva, directamente desde la línea de comandos.",
    github: "https://github.com/robertcanoe/escape-terminal",
    image: "/assets/images/projects/img_project2.webp",
    tags: ["HTML", "CSS", "JavaScript"],
    link: "https://robertcanoe.github.io/escape-terminal/"
  },
  {
    title: "Museo Etnológico Web",
    description: "Sitio web oficial del Museo Etnológico de Almodóvar del Río. Responsive, moderno y con información sobre colecciones, eventos y visitas.",
    github: "https://github.com/robertcanoe/museo-etnologico-web",
    image: "/assets/images/projects/img_project3.webp",
    tags: ["React", "TypeScript", "Tailwind CSS"],
    link: "https://museoetnologico.es"
  },
]
---

{/* Primeros dos proyectos en grid de 2 columnas */}
<div class="grid grid-cols-1 gap-8 md:grid-cols-2 mb-8">
  {
    PROJECTS.slice(0, 2).map(({ image, title, description, tags, link, github }, index) => (
      <FadeIn y={50} duration={1} delay={index * 0.2}>
        <HoverScale>
          <article class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden shadow-md transition-all duration-300 bg-white dark:bg-gray-800 h-full flex flex-col">
            <a href={link} target="_blank" rel="noopener" class="block overflow-hidden">
              <img
                class="w-full h-48 object-cover transition-transform duration-300 hover:scale-105"
                src={image}
                alt={`Captura de pantalla del proyecto ${title}`}
                loading="lazy"
                decoding="async"
                fetchpriority="low"
              />
            </a>
            <div class="p-6 flex flex-col flex-1">
              <h3 class="text-xl font-semibold mb-3">
                <a href={link} target="_blank" rel="noopener" class="hover:text-blue-500 dark:hover:text-blue-400 transition-colors duration-300">
                  {title}
                </a>
              </h3>
              <p class="text-gray-600 dark:text-gray-300 mb-4 leading-relaxed flex-1">{description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {tags.map((tag) => (
                  <span class="bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded-full px-3 py-1 text-sm font-medium">
                    {tag}
                  </span>
                ))}
              </div>
              <div class="flex gap-4 mt-auto">
                <a
                  href={link}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-1.5 text-sm bg-blue-500 hover:bg-blue-600 text-white px-3 py-1.5 rounded-lg transition-colors"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  Ver demo
                </a>
                {github && (
                  <a
                    href={github}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center gap-1.5 text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors border border-blue-300 dark:border-blue-600 px-3 py-1.5 rounded-lg"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                    </svg>
                    Código
                  </a>
                )}
              </div>
            </div>
          </article>
        </HoverScale>
      </FadeIn>
    ))
  }
</div>

{/* Tercer proyecto destacado en ancho completo */}
<div class="mt-12">
  {
    PROJECTS.slice(2, 3).map(({ image, title, description, tags, link, github }) => (
      <FadeIn y={50} duration={1} delay={0.4}>
        <HoverScale>
          <article class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden shadow-lg transition-all duration-300 bg-white dark:bg-gray-800">
            <div class="md:flex">
              <div class="md:w-1/2 md:h-[300px]">
                <a href={link} target="_blank" rel="noopener" class="block h-full overflow-hidden">
                  <img
                    class="w-full h-64 md:h-full object-cover object-center transition-transform duration-300 hover:scale-105"
                    src={image}
                    alt={`Captura de pantalla del proyecto ${title}`}
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                  />
                </a>
              </div>
              <div class="p-6 md:w-1/2 flex flex-col justify-center">
                <h3 class="text-2xl font-semibold mb-4">
                  <a href={link} target="_blank" rel="noopener" class="hover:text-blue-500 dark:hover:text-blue-400 transition-colors duration-300">
                    {title}
                  </a>
                </h3>
                <p class="text-gray-600 dark:text-gray-300 mb-6 leading-relaxed">{description}</p>
                <div class="flex flex-wrap gap-2 mb-6">
                  {tags.map((tag) => (
                    <span class="bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded-full px-3 py-1 text-sm font-medium">
                      {tag}
                    </span>
                  ))}
                </div>
                <div class="flex gap-4">
                  <a
                    href={link}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center gap-1.5 text-sm bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    Ver demo
                  </a>
                  {github && (
                    <a
                      href={github}
                      target="_blank"
                      rel="noopener"
                      class="inline-flex items-center gap-1.5 text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors border border-blue-300 dark:border-blue-600 px-4 py-2 rounded-lg"
                    >
                      <svg fill="currentColor" class="w-4 h-4" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.6 9.6 0 0 1 12 6.844a9.6 9.6 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2" clip-rule="evenodd"/></svg>
                      Código
                    </a>
                  )}
                </div>
              </div>
            </div>
          </article>
        </HoverScale>
      </FadeIn>
    ))
  }
</div>
