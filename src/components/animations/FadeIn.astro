---
interface Props {
  y?: number;
  x?: number;
  duration?: number;
  delay?: number;
  class?: string;
}

const {
  y = 0,
  x = 0,
  duration = 1,
  delay = 0,
  class: className = "",
} = Astro.props;
---

<div
  class:list={[className]}
  data-fade-in
  data-y={y}
  data-x={x}
  data-duration={duration}
  data-delay={delay}
  style="opacity: 0"
>
  <slot />
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initAnimation() {
    ScrollTrigger.getAll().forEach((t) => t.kill());

    document.querySelectorAll<HTMLElement>("[data-fade-in]").forEach((el) => {
      const y        = Number(el.getAttribute("data-y"))        || 0;
      const x        = Number(el.getAttribute("data-x"))        || 0;
      const duration = Number(el.getAttribute("data-duration")) || 1;
      const delay    = Number(el.getAttribute("data-delay"))    || 0;

      gsap.fromTo(
        el,
        { opacity: 0, y, x },
        {
          opacity: 1,
          y: 0,
          x: 0,
          duration,
          delay,
          ease: "power2.out",
          scrollTrigger: {
            trigger: el,
            start: "top bottom-=100",
            toggleActions: "play none none reverse",
          },
        }
      );
    });
  }

  document.addEventListener("astro:page-load", initAnimation);
</script>
