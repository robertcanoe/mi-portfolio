---
interface Props {
  text: string;
  delay?: number;
  speed?: number;
  class?: string;
  cursor?: boolean;
  loop?: boolean;
  loopDelay?: number;
  intersect?: boolean;
}

const {
  text,
  delay = 0,
  speed = 50,
  class: className = "",
  cursor = true,
  loop = false,
  loopDelay = 2000,
  intersect = true,
} = Astro.props;
---

<span
  class:list={["tw-root", className]}
  data-typewriter
  data-text={text}
  data-delay={delay}
  data-speed={speed}
  data-loop={loop}
  data-loop-delay={loopDelay}
  data-intersect={intersect}
>
  <span class="tw-text" aria-live="polite" aria-label={text}></span>
  {cursor && <span class="tw-cursor" aria-hidden="true">|</span>}
</span>

<script>
  const instances = new WeakMap<Element, () => void>();

  function runTypewriter(wrapper: Element) {
    const text      = wrapper.getAttribute("data-text") ?? "";
    const delay     = Number(wrapper.getAttribute("data-delay"))      || 0;
    const speed     = Number(wrapper.getAttribute("data-speed"))      || 50;
    const loop      = wrapper.getAttribute("data-loop")      === "true";
    const loopDelay = Number(wrapper.getAttribute("data-loop-delay")) || 2000;

    const textEl   = wrapper.querySelector<HTMLElement>(".tw-text");
    const cursorEl = wrapper.querySelector<HTMLElement>(".tw-cursor");

    if (!textEl) return;

    instances.get(wrapper)?.();

    let cancelled = false;
    let timerId: ReturnType<typeof setTimeout>;

    instances.set(wrapper, () => {
      cancelled = true;
      clearTimeout(timerId);
    });

    const setCursorTyping = (typing: boolean) => {
      cursorEl?.classList.toggle("tw-cursor--typing", typing);
      cursorEl?.classList.remove("tw-cursor--hidden");
    };
    const hideCursor = () => cursorEl?.classList.add("tw-cursor--hidden");

    function type() {
      if (cancelled) return;
      textEl!.textContent = "";
      setCursorTyping(true);
      let i = 0;

      const addChar = () => {
        if (cancelled) return;
        if (i < text.length) {
          textEl!.textContent = text.substring(0, ++i);
          timerId = setTimeout(addChar, speed);
        } else {
          setCursorTyping(false);
          timerId = setTimeout(loop ? erase : hideCursor, loop ? loopDelay : 1500);
        }
      };
      addChar();
    }

    function erase() {
      if (cancelled) return;
      setCursorTyping(true);
      const shrink = () => {
        if (cancelled) return;
        const current = textEl!.textContent ?? "";
        if (current.length > 0) {
          textEl!.textContent = current.slice(0, -1);
          timerId = setTimeout(shrink, speed / 2);
        } else {
          timerId = setTimeout(type, 400);
        }
      };
      shrink();
    }

    timerId = setTimeout(type, delay);
  }

  function initAll() {
    document.querySelectorAll<Element>("[data-typewriter]").forEach((el) => {
      const useIntersect = el.getAttribute("data-intersect") !== "false";

      if (useIntersect) {
        const observer = new IntersectionObserver(
          ([entry]) => {
            if (!entry.isIntersecting) return;
            observer.unobserve(el);
            runTypewriter(el);
          },
          { threshold: 0.2 }
        );
        observer.observe(el);
      } else {
        runTypewriter(el);
      }
    });
  }

  document.addEventListener("astro:page-load", initAll);
</script>

<style>
  .tw-root {
    display: inline-flex;
    align-items: baseline;
    gap: 1px;
  }

  .tw-cursor {
    display: inline-block;
    font-weight: 300;
    animation: tw-blink 1s step-end infinite;
    transition: opacity 0.4s ease;
  }

  .tw-cursor--typing {
    animation: none;
    opacity: 1;
  }

  .tw-cursor--hidden {
    animation: none;
    opacity: 0;
  }

  @keyframes tw-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>
