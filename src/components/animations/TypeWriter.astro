---
interface Props {
  text: string;
  delay?: number;
  speed?: number;
  class?: string;
  cursor?: boolean;
}

const {
  text,
  delay = 0,
  speed = 50,
  class: className = "",
  cursor = true
} = Astro.props;
---

<span
  class:list={[className]}
  data-gsap="type-writer"
  data-text={text}
  data-delay={delay}
  data-speed={speed}
></span>
{cursor && (
  <span
    class="after:content-['|'] after:ml-1 after:animate-blink inline-block"
    data-cursor
  ></span>
)}

<script>
  function typeWriter(element: Element) {
    const text = element.getAttribute("data-text") || "";
    const delay = Number(element.getAttribute("data-delay")) || 0;
    const speed = Number(element.getAttribute("data-speed")) || 50;
    const cursor = element.nextElementSibling as HTMLElement;

    // Cancelar timeout previo si existe (re-renders)
    const existingId = element.getAttribute("data-timeout-id");
    if (existingId) clearTimeout(Number(existingId));

    element.textContent = "";
    if (cursor) cursor.style.opacity = "1";

    function writeText() {
      let i = 0;
      function addNextChar() {
        if (i < text.length) {
          element.textContent = text.substring(0, i + 1);
          i++;
          setTimeout(addNextChar, speed);
        } else {
          if (cursor) {
            setTimeout(() => {
              cursor.style.transition = "opacity 0.3s ease";
              cursor.style.opacity = "0";
            }, 500);
          }
        }
      }
      addNextChar();
    }

    const id = setTimeout(writeText, delay);
    element.setAttribute("data-timeout-id", id.toString());
  }

  function initTypeWriters() {
    // Pequeño tick para asegurar que GSAP ya aplicó opacity:1 al FadeIn padre
    requestAnimationFrame(() => {
      document.querySelectorAll('[data-gsap="type-writer"]').forEach(typeWriter);
    });
  }

  // Una sola inicialización, sin duplicados
  document.addEventListener("astro:page-load", initTypeWriters);
  document.addEventListener("DOMContentLoaded", initTypeWriters);
</script>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .animate-blink {
    animation: blink 1s step-end infinite;
  }
</style>